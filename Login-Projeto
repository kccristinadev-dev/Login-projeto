<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Login</title>
  
  <style type="text/css">
  
  /* tudo*/
body {
  display: flex; 
  /* ativa o flexbox */
  justify-content: center;   /* centraliza horizontalmente */
  align-items: center;       /* centraliza verticalmente */
  height: 100vh;             /* ocupa 100% da altura da tela */
  margin: 0;                 /* remove margens padrão */
}
.container {
  width: 600px;
  max-width: 90%;
  padding: 20px;
  border: 2px solid #836FFF;
  border-radius: 20px;
  text-align: center;
  box-sizing: border-box;
  background-color: white;
}

  
  /* opçoes*/    
.campo {
       
  margin-bottom: 15px;
} 
.campo input{
    width: 100%;
    box-sizing: border-box;
    border: 1px solid #6959CD;
    padding: 10px 15px;
    height: 40px;
    font-size: 16px;
    border-radius: 30px;
}
.campo button {
    padding: 5px;
  margin-left: 5px;
  height: 30px;
  border-radius: 15px;
  cursor: pointer;
}
.senha-container {
  display: flex;
  align-items: center;
 /* botão à direita do input */
  position: relative;
}
.senha-container input {
 width: 100%;
  padding-right: 40px; /* deixa espaço pro botão */
}
.senha-container button {
  position: absolute;
  right: 5px;
  height: 30px;
  width: 30px;
  border-radius: 50%;
  border: none;
  background-color: #836FFF;
  color: white;
  cursor: pointer;
  justify-content: center;
  align-items: center;
  font-size: 16px;
}

button {
    -webkit-tap-highlight-color: transparent;

  background-color: #836FFF;
  color: white;
  border: none;
  border-radius: 15px;
  padding: 10px 25px;
  cursor: pointer;
  font-size: 16px;
  transition: 0.2s;
  outline: none;
}
button:focus{
    outline: none;
    box-shadow: none;
}
button:active {
  opacity: 0.7; /* dá um feedback visual quando clica */
}
button:hover {
transform: translateY(-2px);
    
    
} 

#saudacao{
    margin: 15px 0;
    font-weight: bold;
    font-size: 18px;
    color: #333;
}

  </style>
  
  
  
</head>

<body>
<div class="container">
  <h1>Faça seu login</h1>

  <div class="campo">
    <input type="text" id="nome" placeholder="Digite seu nome">
  </div>

  <div class="campo">
    <input type="email" id="email" placeholder="Seu email" required>
  </div>
<div class="campo senha-container">
  <input type="password" id="senha" placeholder="Digite sua senha">
  <button type="button" onclick="mostrarsenha()">👁</button>
</div>

    <div id="saudacao">
    </div>
    <button onclick="mostrarsaudacao()">Entrar</button>
 </div>
   
<script>
function mostrarsenha() {
  const senha = document.getElementById('senha');

  if (senha.type === 'password') {
    senha.type = 'text';
  } else {
    senha.type = 'password';
    
  }
  
}
function validarEmail(email){
    
    return email.includes("@") && email.includes(".");
    
}

function mostrarsaudacao(){
    
  const nome=document.getElementById('nome').value.trim();
    const email=document.getElementById('email').value.trim();
      const senha=document.getElementById('senha').value.trim();
  
  
  
  let faltando=[];
  
  if (!nome) faltando.push('nome');
  if (!email) faltando.push('email');
  if (!senha) faltando.push('senha');
  
    if (faltando.length > 0){
      alert("por favor preencha os campo(s): "+ faltando.join(', '));
      return;
      
      
  }
    if (senha.length < 6){
      alert("por favor digite uma senha com 6 caracteres");
      return;
  }
    if (!validarEmail(email)){
      alert("por favor digite um email válido");
      return;
  }


  
  
    const saudacao=document.getElementById('saudacao');
     saudacao.textContent = `Ola, ${nome}! Seja bem vindo(a)`;
}


</script>

</body>
</html>
